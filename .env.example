# Aeon — Supabase connection (cloud mode)
#
# Copy this file to `.env.local` and fill in the two values from your
# Supabase project: Settings → API.  Leaving them blank runs the app in
# local-only mode (no login, data in the browser's localStorage).
#
# The anon key is a *publishable* key — safe to ship to the browser.
# Row-Level Security (see supabase/schema.sql) is what protects user data.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
